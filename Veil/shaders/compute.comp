#version 450

layout(local_size_x = 64) in;

layout(std430, binding = 0) buffer ResultBuffer {
    float results[];
};

void main() {
    uint idx = gl_GlobalInvocationID.x;
    float val = float(idx);

    // FMA chain, hard to optimize away, heavy on ALU
    for (int i = 0; i < 1000; i++) {
        val = val * 1.0001 + 0.0001;
    }

    results[idx] = val;
}