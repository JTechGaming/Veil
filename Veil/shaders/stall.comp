#version 450

layout(local_size_x = 64) in;

layout(std430, binding = 0) buffer DummyBuffer {
    float data[];
};

void main() {
    uint idx = gl_GlobalInvocationID.x;
    float val = data[idx];
    for (uint i = 0; i < 1000u; i++) {
        val = val * 1.0001 + 0.0001;
    }
    data[idx] = val;
}